# ETF NEXUS 优化版配置

# 行情刷新间隔（分钟）
REFRESH_MINUTES=1

# K线数据刷新间隔（分钟）- 建议60分钟以上，避免触发限流
KLINE_REFRESH_MINUTES=60

# K线批量大小 - 减小到1，避免触发限流
KLINE_BATCH_SIZE=1

# 基础请求间隔（秒）
BASE_REQUEST_INTERVAL=2.0

# 最大请求间隔（秒）
MAX_REQUEST_INTERVAL=10.0

# 熔断阈值：连续失败多少次后暂停
CIRCUIT_BREAKER_THRESHOLD=5

# 熔断冷却时间（秒）
CIRCUIT_BREAKER_COOLDOWN=300

# 代理设置（如果需要）
# AKSHARE_PROXY=http://your-proxy:8080
