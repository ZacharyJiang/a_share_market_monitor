# ETF NEXUS 优化版配置

# ============================================
# 基础配置
# ============================================
# 行情刷新间隔（分钟）
REFRESH_MINUTES=1

# K线数据刷新间隔（分钟）- 建议60分钟以上，避免触发限流
KLINE_REFRESH_MINUTES=60

# K线批量大小 - 减小到1，避免触发限流
KLINE_BATCH_SIZE=1

# 基础请求间隔（秒）
BASE_REQUEST_INTERVAL=2.0

# 最大请求间隔（秒）
MAX_REQUEST_INTERVAL=10.0

# 熔断阈值：连续失败多少次后暂停
CIRCUIT_BREAKER_THRESHOLD=5

# 熔断冷却时间（秒）
CIRCUIT_BREAKER_COOLDOWN=300

# ============================================
# 数据模式配置
# ============================================
# 强制使用Mock数据（用于测试）
USE_MOCK=false

# 强制刷新（非交易时间也刷新）
FORCE_REFRESH=false

# ============================================
# 代理配置 - 单代理模式（传统方式）
# ============================================
# 单一代理地址
# AKSHARE_PROXY=http://your-proxy:8080

# ============================================
# 代理池配置 - 多代理模式（推荐）
# ============================================
# 启用代理池
USE_PROXY_POOL=false

# 启用免费代理（可选，稳定性较差）
USE_FREE_PROXIES=false

# 代理池JSON配置（多个代理）
# 格式: [{"http": "http://ip1:port1", "https": "https://ip1:port1", "name": "代理1"}, {...}]
# PROXY_POOL=[{"http": "http://123.45.67.89:8080", "https": "http://123.45.67.89:8080", "name": "代理1"}]

# ============================================
# 示例：国内代理服务商
# ============================================
# 快代理：https://www.kuaidaili.com/
# 站大爷：http://www.zdaye.com/
# 芝麻代理：http://www.zhimaruanjian.com/
# 阿布云：https://www.abuyun.com/

# 代理池配置示例（使用快代理）：
# PROXY_POOL=[
#   {"http": "http://username:password@proxy1.kuaidaili.com:8080", "name": "快代理1"},
#   {"http": "http://username:password@proxy2.kuaidaili.com:8080", "name": "快代理2"}
# ]
